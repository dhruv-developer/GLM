# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ziel-mas

# Redis Configuration
REDIS_URI=redis://localhost:6379/0

# Security
JWT_SECRET=your-jwt-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# GLM API Configuration
GLM_API_KEY=your-glm-api-key-here
GLM_API_URL=https://api.glm.ai/v1

# Z.AI Web Search MCP Configuration
ZAI_API_KEY=your-zai-api-key-here
ZAI_API_URL=https://open.bigmodel.cn/api/paas/v4

# Z.AI GLM Vision API Configuration
# Get your API key from: https://z.ai/manage-apikey/apikey-list
# Used for image and video analysis capabilities
ZAI_VISION_API_KEY=your-zai-vision-api-key-here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development
